{
  "name": "location-intelligence",
  "private": true,
  "packageManager": "pnpm@9.15.4",
  "scripts": {
    "dev:web": "pnpm --filter @location-intelligence/web dev",
    "build:web": "pnpm --filter @location-intelligence/web build",
    "lint:web": "pnpm --filter @location-intelligence/web lint",
    "test:web": "pnpm --filter @location-intelligence/web test",
    "generate:types": "pnpm --filter @location-intelligence/web generate:types",
    "services:up": "docker compose up -d",
    "services:down": "docker compose down"
  },
  "devDependencies": {
    "turbo": "^2.4.0"
  }
}
